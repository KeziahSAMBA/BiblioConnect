{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
    <div style="position: absolute; top: 20px; right: 20px;">
        <a href="{{ path('app_logout') }}" style="padding: 10px 20px; background-color: #dc3545; color: white; text-decoration: none; border-radius: 5px; font-size: 14px;">Déconnexion</a>
    </div>

    <div style="max-width: 1100px; margin: 0 auto; padding: 24px;">
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-bottom: 24px;">
            <div>
                <h1 style="margin: 0;">Profil de {{ user.prenom }} {{ user.nom }}</h1>
                <p style="margin: 8px 0 0 0; color: #555;">Consultez ici vos réservations et vos favoris.</p>
            </div>
            <a href="{{ path('user_dashboard') }}" style="padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 8px;">← Retour au dashboard</a>
        </div>

        <section style="margin-bottom: 28px; padding: 20px; border-radius: 12px; background: #ffffff; border: 1px solid #e8eaed;">
            <h2 style="margin-top: 0;">Mes réservations</h2>
            {% if reservations is not empty %}
                <table style="width: 100%; border-collapse: collapse; margin-top: 16px;">
                    <thead>
                        <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                            <th style="padding: 12px; text-align: left;">Livre</th>
                            <th style="padding: 12px; text-align: left;">Période</th>
                            <th style="padding: 12px; text-align: left;">Statut</th>
                            <th style="padding: 12px; text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reservation in reservations %}
                            <tr style="border-bottom: 1px solid #e9ecef;">
                                <td style="padding: 12px;"><a href="{{ path('user_livre_detail', {id: reservation.livre.id}) }}" style="color: #007bff; text-decoration: none;">{{ reservation.livre.titre }}</a></td>
                                <td style="padding: 12px;">{{ reservation.dateDebut|date('d/m/Y') }} - {{ reservation.dateFin|date('d/m/Y') }}</td>
                                <td style="padding: 12px;">{{ reservation.statut }}</td>
                                <td style="padding: 12px; text-align: center;">
                                    {% if reservation.statut == 'actif' %}
                                        <form method="post" action="{{ path('user_reservation_terminer', {id: reservation.id}) }}" style="display: inline;">
                                            <button type="submit" style="padding: 6px 12px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px;">✓ Marquer terminée</button>
                                        </form>
                                    {% elseif reservation.statut == 'en_attente' %}
                                        <form method="post" action="{{ path('user_reservation_supprimer', {id: reservation.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer cette réservation ?');">
                                            <button type="submit" style="padding: 6px 12px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px;">🗑 Supprimer</button>
                                        </form>
                                    {% else %}
                                        <span style="color: #6c757d; font-size: 13px;">Aucune action</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div style="padding: 18px; border-radius: 12px; background: #f8f9fa; color: #495057;">Vous n'avez pas encore de réservation.</div>
            {% endif %}
        </section>

        <section style="padding: 20px; border-radius: 12px; background: #ffffff; border: 1px solid #e8eaed;">
            <h2 style="margin-top: 0;">Mes favoris</h2>
            {% if favoris is not empty %}
                <ul style="margin: 16px 0 0 20px; color: #495057;">
                    {% for favori in favoris %}
                        <li style="margin-bottom: 10px;"><a href="{{ path('user_livre_detail', {id: favori.livre.id}) }}" style="color: #007bff; text-decoration: none;">{{ favori.livre.titre }}</a> — ajouté le {{ favori.createdAt|date('d/m/Y') }}</li>
                    {% endfor %}
                </ul>
            {% else %}
                <div style="padding: 18px; border-radius: 12px; background: #fff3cd; color: #856404;">Aucun favori enregistré. La fonctionnalité favoris n'est pas encore activée dans le back-end.</div>
            {% endif %}
        </section>
    </div>
{% endblock %}
